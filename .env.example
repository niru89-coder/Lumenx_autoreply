# Copy this file to .env and fill in real values. Never commit .env.

ANTHROPIC_API_KEY=

LUMENX_BASE_URL=https://lumenx-demo.up.railway.app
LUMENX_ADMIN_TOKEN=

# Optional overrides
LLM_CALLS_LOG=data/llm_calls.jsonl
LUMENX_POLL_INTERVAL_SECONDS=5

# Phase 8: Auto-send router
# Set AUTO_SEND_ENABLED=true only after Phase 7 AUC >= 0.75 and manual review.
AUTO_SEND_ENABLED=false
AUTO_SEND_THRESHOLD=0.90
AUTO_SEND_BLOCKED_INTENTS=pricing,cancellation
