# Copy this file to .env and fill in real values. Never commit .env.

ANTHROPIC_API_KEY=

LUMENX_BASE_URL=https://lumenx-demo.up.railway.app
LUMENX_ADMIN_TOKEN=

# Optional overrides
LLM_CALLS_LOG=data/llm_calls.jsonl
LUMENX_POLL_INTERVAL_SECONDS=5

# Phase 8: Auto-send router
# Set AUTO_SEND_ENABLED=true only after Phase 7 AUC >= 0.75 and manual review.
AUTO_SEND_ENABLED=false
AUTO_SEND_THRESHOLD=0.90
AUTO_SEND_BLOCKED_INTENTS=pricing,cancellation

# Phase 10: Deployment
# Comma-separated origins added to the CORS allowlist (localhost is always allowed).
# In production set this to the dashboard's Railway URL, e.g.
#   DASHBOARD_URL=https://dashboard-xxxx.up.railway.app
DASHBOARD_URL=
